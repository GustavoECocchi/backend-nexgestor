# ─────────────────────────────────────────────────────────
# NexGestor — Variáveis de ambiente
# ─────────────────────────────────────────────────────────
# Copie este arquivo para `.env` e preencha com seus valores reais.
# O arquivo `.env` está no .gitignore — NUNCA commitar com keys reais.
# ─────────────────────────────────────────────────────────

# ── App ─────────────────────────────────────────────────
APP_NAME=NexGestor
DEBUG=True

# ── CORS ────────────────────────────────────────────────
# CORS_ORIGINS aceita JSON OU vírgula-separada (os dois funcionam):
#   CORS_ORIGINS=http://localhost:3000,http://localhost:5173
#   CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
#
# Em dev, o regex abaixo já libera qualquer extensão Chrome/Brave,
# então normalmente você NÃO precisa mexer em CORS_ORIGINS para a extensão.
#
# CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
#
# Em produção, troque pela origin real do app e/ou pela origin fixa da
# extensão publicada (o ID fica estável depois de publicar na store):
# CORS_ORIGINS=["https://app.nexgestor.com","chrome-extension://abcdefghijklmnopabcdefghijklmnop"]
#
# Regex que casa a origin da extensão sem fixar o ID (útil em dev).
# Deixe vazio (CORS_ORIGIN_REGEX=) para desativar e só aceitar a lista acima.
# CORS_ORIGIN_REGEX=chrome-extension://.*

# ── Gemini (IA) ─────────────────────────────────────────
# Pegue sua API key em: https://aistudio.google.com/apikey
#
# A IA é OPCIONAL e pode ser desligada de duas formas (qualquer uma basta):
#   1. Deixar GEMINI_API_KEY em branco (abaixo), OU
#   2. Definir GEMINI_ENABLED=False
# Com a IA desligada, o engine determinístico entrega a análise completa
# sozinho — o campo `ai_insights` da resposta vem como null. Nada quebra.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_ENABLED=True
GEMINI_TIMEOUT_SECONDS=8.0
